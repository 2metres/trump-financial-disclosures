oc_id":13,"doc_url":14,"form_type":16},"CACI International, unvested restricted stock units",8757,25628,"8",4,{"description":116,"appointee_id":37,"dsid":62,"endnote":7,"entity_id":117,"id":118,"income_amount":7,"income_category_id":38,"income_type":66,"line_no":119,"metadata":66,"value_category_id":67,"doc_id":13,"doc_url":14,"form_type":16},"“Audible Easter Egg,” Patent # D/789,241 (value not readily ascertainable)",13357,25632,"9",{"description":121,"appointee_id":37,"dsid":62,"endnote":7,"entity_id":122,"id":123,"income_amount":7,"income_category_id":38,"income_type":66,"line_no":124,"metadata":66,"value_category_id":78,"doc_id":13,"doc_url":14,"form_type":16},"CACI International, Inc. (CACI)",8756,25625,"10",{"description":44,"appointee_id":37,"dsid":78,"endnote":7,"entity_id":45,"id":126,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":41,"metadata":127,"value_category_id":7,"doc_id":13,"doc_url":14,"form_type":16},25634,"My participation in the employee stock purchase plan will cease upon my separation from the firm. This plan currently has no cash or other assets. (2023-06-01)",{"description":44,"appointee_id":37,"dsid":78,"endnote":7,"entity_id":45,"id":129,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":47,"metadata":130,"value_category_id":7,"doc_id":13,"doc_url":14,"form_type":16},25633,"I will continue to participate in this defined contribution plan.  The plan sponsor will not make further contributions after my separation. (2021-10-01)",{"description":44,"appointee_id":37,"dsid":78,"endnote":7,"entity_id":45,"id":132,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":53,"metadata":133,"value_category_id":7,"doc_id":13,"doc_url":14,"form_type":16},25636,"Pursuant to company policy, following my termination, I will receive a bonus for services rendered in fiscal year 2025 that started in June 2024, which, if I terminate prior to the end of the fiscal year, will be pro-rated to reflect my work prior to accepting government employment. If I am still employed by CACI when fiscal year 2026 starts in June 2025, I also will be eligible for a pro-rated bonus for fiscal year 2026 for work I perform through my date of termination. This bonus will be paid after assuming the duties of the position of Under Secretary, but will be based solely on work completed before government employment. (2021-10-01)",{"description":44,"appointee_id":37,"dsid":78,"endnote":7,"entity_id":45,"id":135,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":59,"metadata":136,"value_category_id":7,"doc_id":13,"doc_url":14,"form_type":16},25637,"Pursuant to the company’s restricted stock unit plan, I will forfeit my unvested restricted stock units upon my separation from the firm. (2023-01-01)",{"description":44,"appointee_id":37,"dsid":78,"endnote":7,"entity_id":45,"id":138,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":95,"metadata":139,"value_category_id":7,"doc_id":13,"doc_url":14,"form_type":16},25635,"Pursuant to CACI policy for departing executives, I will receive a lump sum severance payment within 30 days of my separation from the firm. (2021-10-01)",{"description":44,"appointee_id":37,"dsid":114,"endnote":7,"entity_id":45,"id":141,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":41,"metadata":142,"value_category_id":7,"doc_id":13,"doc_url":14,"form_type":16},25638,"Vice President, Navy and Marine Corps",{"description":80,"appointee_id":37,"dsid":83,"endnote":7,"entity_id":81,"id":144,"income_amount":7,"income_category_id":145,"income_type":84,"line_no":41,"metadata":7,"value_category_id":67,"doc_id":13,"doc_url":14,"form_type":16},25639,6,{"description":147,"appointee_id":37,"dsid":145,"endnote":7,"entity_id":148,"id":149,"income_amount":7,"income_category_id":38,"income_type":66,"line_no":41,"metadata":7,"value_category_id":83,"doc_id":13,"doc_url":14,"form_type":16},"US BANK #1 (cash)",19365,25640,{"description":151,"appointee_id":37,