pointee_id":42,"dsid":86,"endnote":7,"entity_id":200,"id":204,"income_amount":7,"income_category_id":43,"income_type":89,"line_no":205,"metadata":89,"value_category_id":118,"doc_id":14,"doc_url":25,"form_type":27},55863,"11",{"description":207,"appointee_id":42,"dsid":86,"endnote":7,"entity_id":208,"id":209,"income_amount":7,"income_category_id":43,"income_type":89,"line_no":210,"metadata":89,"value_category_id":90,"doc_id":14,"doc_url":25,"form_type":27},"International Business Machines, unvested performance stock units",18479,55869,"12",{"description":212,"appointee_id":42,"dsid":86,"endnote":7,"entity_id":213,"id":214,"income_amount":7,"income_category_id":43,"income_type":89,"line_no":215,"metadata":89,"value_category_id":90,"doc_id":14,"doc_url":25,"form_type":27},"International Business Machines, vested stock options",18480,55872,"13",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":217,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":11,"metadata":218,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55891,"Upon my confirmation, IBM will accelerate the vesting of my outstanding unvested stock options. The IBM Long Term Performance Plan provides the Compensation Committee the discretion to accelerate the vesting of the stock options. Once these stock options are vested, I will exercise the stock options and divest of the stock. (2022-02-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":220,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":51,"metadata":221,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55888,"My 2024 performance bonus, payable in early April of 2025, will be $1,680,120. The payment is made pursuant to IBM's executive compensation policy and has already been confirmed by the IBM Board compensation committee. The payment is based on overall IBM performance (50% for meeting free-cash flow growth targets and 50% for meeting revenue growth targets), with an individual multiplier based on individual performance. (2024-01-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":223,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":57,"metadata":224,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55890,"This deferred compensation plan is a non-qualified plan that has been funded by a combination of my personal deferrals from compensation and IBM's company match. Per my elections on file, the plan will pay out 100% via a lump-sum distribution immediately following my final day at IBM. (2016-08-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":226,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":63,"metadata":227,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55893,"Upon my confirmation, the company will accelerate the vesting of my outstanding unvested restricted stock units (RSU). The IBM Long Term Performance Plan provides the Compensation Committee the discretion to accelerate the vesting of the RSUs.  Once the RSUs are vested, IBM will distribute shares to me, and I will divest the stock. (2017-06-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":229,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":69,"metadata":230,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55889,"My participation in the employee stock purchase plan (ESPP) will cease upon my separation from the company. (2022-04-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":232,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":76,"metadata":233,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55885,"I will continue to participate in this defined contribution plan.  The sponsor will no longer makes contributions to the plan once I resign from IBM. (2003-08-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":235,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":82,"metadata":236,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55886,"I will receive a lump sum payout of my cash balance plan upon resignation, which will get rolled into my IRA. (2003-07-01)",{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":238,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":125,"metadata":236,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55887,{"description":54,"appointee_id":42,"dsid":166,"endnote":7,"entity_id":55,"id":240,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":155,"metadata":241,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55892,"Upon my confirmation, the company will accelerate the vesting of my outstanding unvested performance stock units (PSU). The IBM Long Term Performance Plan provides the Compensation Committee the discretion to accelerate the vesting of the PSUs. Once the PSUs are vested, IBM will distribute shares to me, and I will divest the stock. (2016-06-01)",{"description":54,"appointee_id":42,"dsid":119,"endnote":7,"entity_id":55,"id":243,"income_amount":7,"income_category_id":7,"income_type":7,"line_no":11,"metadata":244,"value_category_id":7,"doc_id":14,"doc_url":25,"form_type":27},55894,"Services as Senior Vice President and Director of Research",{"description":246,"appointee_id":42,"dsid":118,"endnote":7,"entity_id":247,"id":248,"income_amount":124,"income_category_id":7,"income_type":249,"line_no":11,"metadata":7,"value_category_id":95,"doc_id":14,"doc_url":25,"form_type":27},"Community Center of Northern Westchester (resources center)",70433,55895,"salary",{"description":121,"appointee_id":42,"dsid":118,"endnote":7,"entity_id":122,"id":251,"income_amount":124,"income_category_id":7,"income_type":89,"line_no":51,"metadata":7,"value_category_id":95,"doc_id":14